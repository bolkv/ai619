  "orchestration": {
    "consumes": ["image_file"],
    "produces": ["segmentation_result"],
    "priority": 80
  },
  "routing": {
    "trigger_keywords": ["lung", "cxr", "chest x-ray", "lung segmentation", "pspnet", "chestx-det"],
    "result_slot": "segmentation_result"
  }
}
